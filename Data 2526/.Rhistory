# Do anova analysis
aov(slope ~ target_ori * target_presence, regression)
# Do anova analysis
aov(slope ~ target_ori * target_presence, data=regression)
# Do anova analysis
aov(coefs ~ target_ori * target_presence, data=regression)
summary(anova)
# Do anova analysis
anova <- aov(coefs ~ target_ori * target_presence, data=regression)
summary(anova)
